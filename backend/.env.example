# Пример переменных окружения для разработки
# Скопируйте этот файл в .env и заполните своими значениями

# Django конфигурация
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spring_hack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=spring_hack

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email (опционально для отправки писем)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# API конфигурация
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Логирование
LOG_LEVEL=INFO
